#!/bin/sh
# zlabel pre-commit hook -- the Stage-G regression wall.
#
# Runs `make gate` (regenerate the Daniocell baseline, fail on drift or an overcall regression)
# when the engine, panels, or benchmark substrate is staged. Doc-only and unrelated commits skip
# it and stay fast. The gate itself skips when data/ontologies is absent, so this never blocks a
# machine without the corpus. Install with `make hooks`.
if git diff --cached --name-only | grep -qE '^(src/zlabel/|benchmarks/|scripts/check_baseline\.py)'; then
	echo "pre-commit: engine/panels/benchmark staged -> running make gate"
	exec make gate
fi
echo "pre-commit: no engine/panels/benchmark changes -> skipping baseline gate"
